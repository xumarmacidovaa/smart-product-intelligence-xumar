# ==============================================================================
# MILESTONE 4: TRANSFORMERS FOR SEQUENCE CLASSIFICATION (DISTILBERT)
# ==============================================================================

import time
import numpy as np
import tensorflow as tf
from transformers import AutoTokenizer, TFAutoModelForSequenceClassification
from sklearn.metrics import classification_report, f1_score

# 1. Dataset Configuration for Fine-Tuning Simulation
# Real execution targets df_train['text'] and binary labels mapped from ratings
mock_reviews = [
    "This wireless car charger is absolutely amazing and fast.",
    "The screen protector arrived cracked. Completely useless product.",
    "It fits the phone well, but the color fades away quickly.",
    "Superb build quality, survived multiple accidental drops!"
] * 20

# Binary Target Labels (1: Positive Sentiment, 0: Negative Sentiment)
mock_labels = np.array([1, 0, 0, 1] * 20)

print(f"Transformer Pipeline Setup Complete. Active Training Sequences: {len(mock_reviews)}")

# ------------------------------------------------------------------------------
# 2. Tokenization via Pretrained DistilBERT Configuration
# ------------------------------------------------------------------------------
print("\n--- Downloading and Initializing DistilBERT Tokenizer ---")
MODEL_CHECKPOINT = "distilbert-base-uncased"
tokenizer = AutoTokenizer.from_pretrained(MODEL_CHECKPOINT)

# Tokenizing input sequences with standard truncation and padding constraints
tokenized_inputs = tokenizer(
    mock_reviews,
    padding=True,
    truncation=True,
    max_length=64,
    return_tensors="tf"
)

# Structuring into a standard TensorFlow Dataset pipeline
tf_dataset = tf.data.Dataset.from_tensor_slices((
    dict(tokenized_inputs),
    mock_labels
)).batch(8)

# ------------------------------------------------------------------------------
# 3. Model Construction & Fine-Tuning Execution
# ------------------------------------------------------------------------------
print("\n--- Loading Pretrained DistilBERT Sequence Classifier ---")
transformer_network = TFAutoModelForSequenceClassification.from_pretrained(
    MODEL_CHECKPOINT,
    num_labels=2
)

# Compiling network utilizing the Adam optimizer with a lower learning rate for stability
transformer_network.compile(
    optimizer=tf.keras.optimizers.Adam(learning_rate=5e-5),
    loss=tf.keras.losses.SparseCategoricalCrossentropy(from_logits=True),
    metrics=['accuracy']
)

print("Status: Commencing Transformer fine-tuning iterations...")
transformer_network.fit(tf_dataset, epochs=2)

# ------------------------------------------------------------------------------
# 4. Mandated Operational Performance Evaluation (Latency & Cost Audit)
# ------------------------------------------------------------------------------
print("\n--- Executing Inference Latency Audit (Syllabus Metric) ---")

single_sample_text = ["Highly durable tactical cover casing, fits perfectly."]
tokenized_sample = tokenizer(single_sample_text, padding=True, truncation=True, return_tensors="tf")

# Benchmark inference velocity profile
start_time = time.time()
raw_output_logits = transformer_network(tokenized_sample).logits
end_time = time.time()

inference_latency_ms = (end_time - start_time) * 1000
predicted_probability = tf.nn.softmax(raw_output_logits, axis=-1)
predicted_sentiment_class = np.argmax(predicted_probability.numpy(), axis=1)[0]

print(f"Audited Single-Sample Inference Latency : {inference_latency_ms:.2f} ms")
print(f"Predicted Class Output Label            : {predicted_sentiment_class} (Probability: {np.max(predicted_probability):.4f})")

print("\n--- Comparative Structural Resource Diagnostics ---")
print("1. Bag-of-Words Model (Milestone 3 Baseline) -> Latency: ~2 ms | Cost: Extremely Low (CPU Bound)")
print("2. DistilBERT Transformer (Milestone 4 Model) -> Latency: Higher | Cost: Moderate (Requires GPU Acceleration)")
print("Analysis Note: Transformers yield substantial improvements in context preservation at the expense of computational overhead.")

print("\nStatus: Milestone 4 Transformer Classification Pipeline Complete.")